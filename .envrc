# direnv config — sets Hugo module replacement to point at local theme worktree.
#
# direnv users: this loads automatically on `cd`. Run `direnv allow` once.
# Non-direnv: source this manually (`source .envrc`) or use `just hugo …` recipes.
export HUGO_MODULE_REPLACEMENTS="github.com/RijksICTGilde/hugo-theme-ro -> $(pwd)/hugo-theme-ro"
