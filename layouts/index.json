{{- $pages := slice -}}
{{- range where site.RegularPages "Kind" "page" -}}
  {{- $text := .Plain | replaceRE `\{ref:[^}]*\}` "" -}}
  {{- with .Params.kern }}{{ $text = printf "%s %s" $text . }}{{ end -}}
  {{- with .Params.toelichting }}{{ $text = printf "%s %s" $text . }}{{ end -}}
  {{- $synoniemen := "" -}}
  {{- with .Params.synoniemen -}}
    {{- $synoniemen = delimit . " " | replaceRE `\{ref:[^}]*\}` "" -}}
    {{- $text = printf "%s %s" $text $synoniemen -}}
  {{- end -}}
  {{- with .Params.normuitleg -}}
    {{- range . -}}
      {{- with .titel }}{{ $text = printf "%s %s" $text . }}{{ end -}}
      {{- range .voorschriften }}{{ with .tekst }}{{ $text = printf "%s %s" $text . }}{{ end }}{{ end -}}
    {{- end -}}
  {{- end -}}
  {{- $title := .Title -}}
  {{- $section := .Section -}}
  {{- if and .Params.norm_id .Params.norm_titel -}}
    {{- $title = printf "Norm %s: %s" (string .Params.norm_id) .Params.norm_titel -}}
  {{- end -}}
  {{- $pages = $pages | append (dict
    "title" $title
    "url" .RelPermalink
    "section" $section
    "synoniemen" $synoniemen
    "content" ($text | replaceRE `\{ref:[^}]*\}` "")
  ) -}}
{{- end -}}
{{- $pages | jsonify -}}
