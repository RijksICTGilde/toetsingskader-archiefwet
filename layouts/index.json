{{- /* Zoekindex. De body-tekst (toelichting, normuitleg, reikwijdte, zie
       ook, voetnootbronnen) zit in `.Plain`. `kern` staat in de front
       matter en `synoniemen` worden bewust niet getoond maar wel
       geïndexeerd. `markdownify | plainify` maakt er platte tekst van. */ -}}
{{- $pages := slice -}}
{{- $allPages := site.RegularPages | append site.Home -}}
{{- range $allPages -}}
  {{- $text := .Plain -}}
  {{- with .Params.kern }}{{ $text = printf "%s %s" $text (. | markdownify | plainify) }}{{ end -}}
  {{- $synoniemen := "" -}}
  {{- with .Params.synoniemen -}}
    {{- $synoniemen = delimit . " " | markdownify | plainify -}}
    {{- $text = printf "%s %s" $text $synoniemen -}}
  {{- end -}}
  {{- $title := .Title -}}
  {{- /* Section voor top-level pages: home → "home", overige top-level
         (over.md, …) → file-basename zodat priority_sections per pagina kan. */ -}}
  {{- $section := .Section -}}
  {{- if not $section -}}
    {{- if eq .Kind "home" -}}{{- $section = "home" -}}
    {{- else -}}{{- $section = .File.BaseFileName -}}{{- end -}}
  {{- end -}}
  {{- if and .Params.norm_id .Params.norm_titel -}}
    {{- $title = printf "Norm %s: %s" (string .Params.norm_id) .Params.norm_titel -}}
  {{- end -}}
  {{- $pages = $pages | append (dict
    "title" $title
    "url" .RelPermalink
    "section" $section
    "synoniemen" $synoniemen
    "content" $text
  ) -}}
{{- end -}}
{{- $pages | jsonify -}}
