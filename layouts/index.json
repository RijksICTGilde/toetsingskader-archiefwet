{{- $pages := slice -}}
{{- $allPages := site.RegularPages | append site.Home -}}
{{- range $allPages -}}
  {{- $text := .Plain | replaceRE `\{ref:\d+\}` "" -}}
  {{- with .Params.kern }}{{ $text = printf "%s %s" $text . }}{{ end -}}
  {{- with .Params.toelichting }}{{ $text = printf "%s %s" $text . }}{{ end -}}
  {{- $synoniemen := "" -}}
  {{- with .Params.synoniemen -}}
    {{- $synoniemen = delimit . " " | replaceRE `\{ref:\d+\}` "" -}}
    {{- $text = printf "%s %s" $text $synoniemen -}}
  {{- end -}}
  {{- with .Params.normuitleg -}}
    {{- range . -}}
      {{- with .titel }}{{ $text = printf "%s %s" $text . }}{{ end -}}
      {{- range .voorschriften }}{{ with .tekst }}{{ $text = printf "%s %s" $text . }}{{ end }}{{ end -}}
    {{- end -}}
  {{- end -}}
  {{- $title := .Title -}}
  {{- /* Section voor top-level pages: home → "home", overige top-level
         (over.md, …) → file-basename zodat priority_sections per pagina kan. */ -}}
  {{- $section := .Section -}}
  {{- if not $section -}}
    {{- if eq .Kind "home" -}}{{- $section = "home" -}}
    {{- else -}}{{- $section = .File.BaseFileName -}}{{- end -}}
  {{- end -}}
  {{- if and .Params.norm_id .Params.norm_titel -}}
    {{- $title = printf "Norm %s: %s" (string .Params.norm_id) .Params.norm_titel -}}
  {{- end -}}
  {{- $pages = $pages | append (dict
    "title" $title
    "url" .RelPermalink
    "section" $section
    "synoniemen" $synoniemen
    "content" ($text | replaceRE `\{ref:\d+\}` "")
  ) -}}
{{- end -}}
{{- $pages | jsonify -}}
